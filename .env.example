# Copy this file to .env and fill in your own values.
# Never commit your real .env file or private key.

# "paper" (default, no real money, no wallet needed) or "live" (places real orders on Polymarket)
POLYBOT_MODE=paper

# Only required when POLYBOT_MODE=live.
# Private key of the wallet that will sign orders (EOA or the key behind your
# Polymarket proxy/Magic wallet). Keep this secret.
POLYMARKET_PRIVATE_KEY=

# Only required when POLYBOT_MODE=live and you trade through a Polymarket
# proxy/email wallet. This is the address that actually holds the funds
# (shown in the Polymarket UI). For a plain MetaMask/EOA wallet you can
# leave it blank and your signing address will be used.
POLYMARKET_FUNDER_ADDRESS=
